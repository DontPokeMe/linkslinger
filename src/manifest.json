{
  "manifest_version": 3,
  "name": "LinkSlinger: Open Multiple Links at Once",
  "version": "4.0.9",
  "description": "Select multiple links with a drag, then open all in new tabs, copy, or bookmark them at once. Privacy first, open source.",

  "action": {
    "default_popup": "ui/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "ui/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-compat.js", "content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "permissions": [
    "tabs",
    "bookmarks",
    "storage",
    "scripting",
    "clipboardWrite",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
